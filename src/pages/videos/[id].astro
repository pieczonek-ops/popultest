---
import Layout from '../../layouts/Layout.astro';
import { VideoDetail } from '../../components/pages/VideoDetail';
import { videos as mockVideos } from '../../data/mockData';
import { db } from '../../lib/firebase';
import { doc, getDoc } from 'firebase/firestore';

const { id } = Astro.params;

// Fetch video for title
let videoTitle = 'Wideo';
try {
  if (id) {
    const docRef = doc(db, 'videos', id);
    const docSnap = await getDoc(docRef);
    if (docSnap.exists()) {
      videoTitle = docSnap.data().title;
    } else {
      const mock = mockVideos.find(v => v.id === id);
      if (mock) videoTitle = mock.title;
    }
  }
} catch (e) {
  console.error(e);
}
---

<Layout title={videoTitle}>
	<VideoDetail id={id} client:load />
</Layout>
