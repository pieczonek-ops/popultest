---
import Layout from '../../../layouts/Layout.astro';
import { ForumTopicView } from '../../components/pages/ForumTopicView';
import { forumTopics } from '../../../data/mockData';

export function getStaticPaths() {
  return forumTopics.map(topic => ({
    params: { topicId: topic.id },
  }));
}

const { topicId } = Astro.params;
const topic = forumTopics.find(t => t.id === topicId);
---

<Layout title={topic?.title || 'Temat Forum'}>
	<ForumTopicView topicId={topicId} client:load />
</Layout>
