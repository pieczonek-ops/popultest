---
import Layout from '../../../layouts/Layout.astro';
import { ForumTopicView } from '../../../components/pages/ForumTopicView';
import { forumTopics as mockTopics } from '../../../data/mockData';
import { db } from '../../../lib/firebase';
import { doc, getDoc } from 'firebase/firestore';

const { topicId } = Astro.params;

// Fetch topic for title
let topicTitle = 'Temat Forum';
try {
  if (topicId) {
    const docRef = doc(db, 'forum_topics', topicId);
    const docSnap = await getDoc(docRef);
    if (docSnap.exists()) {
      topicTitle = docSnap.data().title;
    } else {
      const mock = mockTopics.find(t => t.id === topicId);
      if (mock) topicTitle = mock.title;
    }
  }
} catch (e) {
  console.error(e);
}
---

<Layout title={topicTitle}>
	<ForumTopicView topicId={topicId} client:load />
</Layout>
