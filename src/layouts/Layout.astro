---
import { Navbar } from '../components/Navbar';
import { CartProvider } from '../context/CartContext';
import '../index.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="GamerGold - Portal dla graczy" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | GamerGold</title>
	</head>
	<body class="bg-dark-bg text-white selection:bg-gold selection:text-black">
		<CartProvider client:load>
			<Navbar client:load />
			<main>
				<slot />
			</main>
		</CartProvider>
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
</style>
